---
import '../styles/global.css';

const themes = [
  { id: 'minimal',   name: 'Minimal',   blurb: 'Pure text, transparent. Lowest distraction.' },
  { id: 'crystal',   name: 'Crystal',   blurb: 'Frosted glass. Refined and clean.' },
  { id: 'bloom',     name: 'Bloom',     blurb: 'Album art blooms behind the lyrics.' },
  { id: 'spotlight', name: 'Spotlight', blurb: 'One line, big, with a stage light behind it.' },
  { id: 'concert',   name: 'Concert',   blurb: 'Apple Music big lyrics. Fills the bar.' },
  { id: 'neon',      name: 'Neon',      blurb: 'Dark, italic, with a saturated halo. Synthwave.' },
];

const features = [
  { icon: '✦', title: 'Per-word reveal',     body: 'Like Apple Music — each word lights up as it’s sung. Interpolated smoothly from line timing.' },
  { icon: '◐', title: 'Adaptive color',      body: 'Wipe color matches the dominant tone of the album art. Each song its own mood.' },
  { icon: '◫', title: 'Six themes',          body: 'From low-distraction Minimal to immersive Concert. Pick once, change anytime.' },
  { icon: '↻', title: 'No login, no setup',  body: 'No Spotify account, no Client ID, no PKCE. Open the app, hit play, click one macOS prompt.' },
  { icon: '◇', title: 'Always-on-top',       body: 'Survives Spaces and fullscreen. Drag anywhere. Click-through with one hotkey.' },
  { icon: '⌁', title: 'Whisper-quiet',       body: '~4 MB app, near-zero CPU when paused. No Electron. Native Swift on macOS.' },
];

const currentWords = ['Lyrics', 'that', 'move', 'with', 'the', 'music', '.'];
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Karacookie — Lyrics that move with the music</title>
    <meta name="description" content="Floating karaoke-style synced lyrics overlay for Spotify and Apple Music. macOS. Zero setup. Open source." />
    <meta property="og:title" content="Karacookie — Lyrics that move with the music" />
    <meta property="og:description" content="Floating karaoke-style synced lyrics for Spotify and Apple Music. macOS. Zero setup." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://karacookie.app" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <nav class="top">
      <a class="brand" href="/">
        <span class="dot"></span>
        Karacookie
      </a>
      <div>
        <a class="link" href="#how">How it works</a>
        <a class="link" href="#themes">Themes</a>
        <a class="link" href="#faq">FAQ</a>
        <a class="link" href="https://github.com/rahuldotbiz/karacookie">GitHub</a>
      </div>
    </nav>

    <header class="hero">
      <span class="eyebrow">v1.0 · macOS</span>
      <h1>Lyrics that <span class="accent">move</span> with the music.</h1>
      <p class="sub">A tiny floating overlay that sings along with Spotify and Apple Music. Per-word karaoke wipe. Six themes. No login, no setup.</p>

      <div class="cta-row">
        <a class="cta" href="#download">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 12.5c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.9-1.4-.1-2.8.8-3.5.8-.7 0-1.9-.8-3.1-.8-1.6 0-3.1.9-3.9 2.4-1.7 2.9-.4 7.2 1.2 9.5.8 1.1 1.7 2.4 3 2.4 1.2 0 1.6-.8 3.1-.8 1.4 0 1.8.8 3.1.8 1.3 0 2.1-1.2 2.9-2.3.9-1.3 1.3-2.6 1.3-2.7-.1 0-2.5-1-2.7-3.9zm-2.4-7.2c.6-.8 1.1-1.9 1-3-1 .1-2.1.7-2.8 1.5-.6.7-1.2 1.8-1 2.9 1.1.1 2.2-.6 2.8-1.4z"/></svg>
          Download for macOS
        </a>
        <a class="cta-secondary" href="#download">
          <span class="badge-windows"><span class="dot-pulse"></span>Windows · WIP</span>
        </a>
      </div>

      <!-- animated lyric mock -->
      <div class="mock" role="img" aria-label="Karacookie floating lyrics overlay demo">
        <div class="mock-inner">
          <div class="line-prev">A floating bar pinned above every app</div>
          <div class="line-current">
            {currentWords.map((w, i) => (
              <span class={`word w${i + 1}`} data-text={w}>{w}{i < currentWords.length - 1 ? ' ' : ''}</span>
            ))}
          </div>
          <div class="line-next">Drag it where you want, hide with ⌥⌘L</div>
        </div>
      </div>
    </header>

    <section id="how" class="wrap">
      <h2>Three steps. That’s it.</h2>
      <p class="lede">No accounts to make. No keys to copy. Just music.</p>
      <div class="steps">
        <div class="step">
          <span class="n">1</span>
          <h3>Play a song</h3>
          <p>Open Spotify or the Music app and press play.</p>
        </div>
        <div class="step">
          <span class="n">2</span>
          <h3>Allow once</h3>
          <p>macOS asks: <em>“Karacookie wants to control Spotify”</em>. Click OK.</p>
        </div>
        <div class="step">
          <span class="n">3</span>
          <h3>Lyrics float on top</h3>
          <p>A translucent bar appears above every window. Drag it anywhere.</p>
        </div>
      </div>
    </section>

    <section id="themes" class="wrap">
      <h2>Six themes. Pick your mood.</h2>
      <p class="lede">From low-distraction Minimal to immersive Concert. Change anytime, even mid-song.</p>
      <div class="themes">
        {themes.map((t) => (
          <div class="theme-card">
            <div class={`theme-preview preview-${t.id}`}>
              <span class="preview-line">she sings the chorus</span>
            </div>
            <div class="meta">
              <div class="name">{t.name}</div>
              <div class="blurb">{t.blurb}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="wrap">
      <h2>Made of small, careful things.</h2>
      <p class="lede">Karacookie sweats the details so you don’t notice it’s there until it sings along.</p>
      <div class="features">
        {features.map((f) => (
          <div class="feature">
            <div class="icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="wrap">
      <h2>What it listens to.</h2>
      <p class="lede">Reads what’s playing locally — no streaming-service auth needed.</p>
      <div class="sources">
        <span class="source-chip live">Spotify</span>
        <span class="source-chip live">Apple Music</span>
        <span class="source-chip wip">Windows · WIP</span>
        <span class="source-chip soon">YouTube Music · v1.1</span>
        <span class="source-chip soon">SoundCloud · v1.1</span>
      </div>
    </section>

    <section id="faq" class="wrap faq">
      <h2>Questions you might have.</h2>
      <p class="lede">If your answer isn't here, file an issue on GitHub and we'll add it.</p>
      <details>
        <summary>Does it cost anything?</summary>
        <p>No. Karacookie is free and open source under MIT. Lyrics come from <a href="https://lrclib.net/">LRCLib</a>, also free.</p>
      </details>
      <details>
        <summary>Do I need Spotify Premium?</summary>
        <p>No. Karacookie reads the playing track from your local Spotify or Music app via AppleScript — works on Free too.</p>
      </details>
      <details>
        <summary>What does “control Spotify” really mean?</summary>
        <p>Just reading <em>name, artist, album, position</em>. Karacookie never plays, pauses, or skips. The macOS prompt uses generic wording.</p>
      </details>
      <details>
        <summary>Does this work in fullscreen apps?</summary>
        <p>Yes. The bar joins all Spaces and floats above fullscreen apps as an auxiliary window. Toggle with <code>⌥⌘L</code>; click-through with <code>⌥⌘K</code>.</p>
      </details>
      <details>
        <summary>What about privacy?</summary>
        <p>Karacookie sends one HTTPS request per track to LRCLib (lyrics) and one to <code>open.spotify.com/oembed</code> (album art). No tracking, no analytics, no account.</p>
      </details>
      <details>
        <summary>When is Windows shipping?</summary>
        <p>The Windows version is in active development. WinUI 3 + SMTC. Watch <a href="https://github.com/rahuldotbiz/karacookie">the repo</a> or open an issue if you want to beta-test.</p>
      </details>
    </section>

    <section id="download" class="wrap" style="text-align:center;">
      <h2>Sing along to everything.</h2>
      <p class="lede" style="margin: 0 auto 32px; text-align:center;">Free. Open source. macOS 14+.</p>
      <a class="cta" href="https://github.com/rahuldotbiz/karacookie/releases/latest">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 12.5c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.9-1.4-.1-2.8.8-3.5.8-.7 0-1.9-.8-3.1-.8-1.6 0-3.1.9-3.9 2.4-1.7 2.9-.4 7.2 1.2 9.5.8 1.1 1.7 2.4 3 2.4 1.2 0 1.6-.8 3.1-.8 1.4 0 1.8.8 3.1.8 1.3 0 2.1-1.2 2.9-2.3.9-1.3 1.3-2.6 1.3-2.7-.1 0-2.5-1-2.7-3.9zm-2.4-7.2c.6-.8 1.1-1.9 1-3-1 .1-2.1.7-2.8 1.5-.6.7-1.2 1.8-1 2.9 1.1.1 2.2-.6 2.8-1.4z"/></svg>
        Download Karacookie
      </a>
    </section>

    <footer>
      <div class="row">
        <a href="https://github.com/rahuldotbiz/karacookie">GitHub</a>
        <a href="https://github.com/rahuldotbiz/karacookie/issues">Report an issue</a>
        <a href="#download">Download</a>
      </div>
      <div>MIT license · Lyrics by LRCLib · Made with care</div>
    </footer>
  </body>
</html>
